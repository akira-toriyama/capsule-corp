#!/bin/sh
# gitmoji + Conventional Commits 形式を検証する commit-msg フック。
# 有効化:  git config core.hooksPath scripts/hooks
# 規約:    docs/commit-convention.md
#
# 形式: <:gitmoji:> <type>(<scope>)<!>: <subject>
#   例:  :sparkles: feat(keymap): 矢印レイヤーを追加
#
# 低依存（POSIX sh + grep のみ）。gitmoji は :code: テキスト形式を必須とする。

msg_file="$1"
# 1 行目（コメント行・空行を除く先頭）を取得
subject="$(grep -vE '^[[:space:]]*#' "$msg_file" | sed '/^[[:space:]]*$/d' | head -n1)"

# Merge / Revert / fixup・squash は通す
case "$subject" in
  "Merge "*|"Revert "*|"fixup! "*|"squash! "*) exit 0 ;;
esac

types='feat|fix|perf|refactor|docs|test|build|ci|chore|style|revert'
pattern="^:[a-z0-9][a-z0-9_+-]*: ($types)(\([^()]+\))?!?: .+"

if printf '%s' "$subject" | grep -qE "$pattern"; then
  exit 0
fi

cat >&2 <<EOF
✖ コミットメッセージが規約に違反しています。

  受領: $subject

  形式: <:gitmoji:> <type>(<scope>)<!>: <subject>
        ^^^^^^^^^^^ :code: テキスト形式必須（絵文字グリフ不可）

  type : $types
  例   : :sparkles: feat(keymap): EIJI に矢印クラスタを追加
         :bug: fix(combos): home-row combo の誤爆を修正
         :boom: feat(keymap)!: base レイヤーを全面再配置

  詳細: docs/commit-convention.md
EOF
exit 1
