{
  // 保存時にフォーマットを実行
  "editor.formatOnSave": true,

  // prettier が扱える言語のみ既定フォーマッタを prettier に固定。
  // .dtsi / .keymap / .conf / .sh / .py 等は対象外（別フォーマッタの領域）。
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  }
}
