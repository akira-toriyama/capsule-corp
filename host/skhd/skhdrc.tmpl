# このファイルは skhdrc の元。編集後 ./render.sh を実行
# 変数は render.sh で定義 → envsubst で ${VAR} を置換

# ---- 共通コマンド定義 ----
.define yabai_focus_prev : yabai -m query --spaces --space | jq -re ".index" | xargs -I{} yabai -m query --windows --space {} | jq -sre 'add | map(select(."is-minimized"==false)) | sort_by(.display, .frame.y, .frame.x, .id) | . as $array | length as $array_length | index(map(select(."has-focus"==true))) as $has_index | if $has_index > 0 then nth($has_index - 1).id else nth($array_length - 1).id end' | xargs -I{} yabai -m window --focus {}

.define yabai_focus_next : yabai -m query --spaces --space | jq -re ".index" | xargs -I{} yabai -m query --windows --space {} | jq -sre 'add | map(select(."is-minimized"==false)) | sort_by(.display, .frame.y, .frame.x, .id) | . as $array | length as $array_length | index(map(select(."has-focus"==true))) as $has_index | if $array_length - 1 > $has_index then nth($has_index + 1).id else nth(0).id end' | xargs -I{} yabai -m window --focus {}

# AltTab (lwouis/alt-tab-macos) を CLI で直接起動する（キー合成ではない）。
# `--show=N` の N は AltTab 設定 → Controls タブのショートカット枠の順（0 始まり）。
# "全スペース表示" 等は枠ごとの設定なので index と意味は AltTab 設定依存。
# このリポジトリ作者の環境では枠1(=--show=1)が全スペース・枠0(=--show=0)が
# 現スペース。AltTab 設定を変えたら下の --show 番号だけ合わせ直す。
.define alttab_all_spaces    : /Applications/AltTab.app/Contents/MacOS/AltTab --show=1
.define alttab_current_space : /Applications/AltTab.app/Contents/MacOS/AltTab --show=0

# ---- バインド ----

# 各バインド直前の `# doc: <動作>` は host/skhd/README.md の一覧生成の
# 唯一ソース（scripts/gen-skhd-doc.py が読む）。バインド行自体は不変。

# doc: タブを左へ（Chrome: Ctrl+Shift+Tab / VS Code: Cmd+Shift+[）
${ULTRA_LL} - ${X_C} [
    "Google Chrome"        : skhd -k "ctrl + shift - tab"
    "Code"                 : skhd -k "cmd + shift - ${BRACKET_OPEN}"
]

# doc: タブを右へ（Chrome: Ctrl+Tab / VS Code: Cmd+Shift+]）
${ULTRA_LL} - ${X_V} [
    "Google Chrome"        : skhd -k "ctrl - tab"
    "Code"                 : skhd -k "cmd + shift - ${BRACKET_CLOSE}"
]

# doc: 前のウィンドウへ（yabai フォーカス）
${ULTRA_LL} - ${X_D} : @yabai_focus_prev

# doc: 次のウィンドウへ（yabai フォーカス）
${ULTRA_LL} - ${X_F} : @yabai_focus_next

# doc: AltTab 起動（全スペース。旧 cmd+ctrl+tab）
${ULTRA_LL} - ${X_A} : @alttab_all_spaces

# doc: AltTab 起動（現スペース。旧 alt+tab）
${ULTRA_LL} - ${X_S} : @alttab_current_space

# ---- emacs/readline 風 Ctrl+key remap ----
# doc: ← Left
ctrl - b : skhd -k "left"
# doc: → Right
ctrl - f : skhd -k "right"
# doc: ↑ Up
ctrl - p : skhd -k "up"
# doc: ↓ Down
ctrl - n : skhd -k "down"
# doc: Backspace
ctrl - h : skhd -k "backspace"
# doc: 前方削除（Forward Delete）
ctrl - d : skhd -k "delete"
# doc: Return
ctrl - j : skhd -k "return"
